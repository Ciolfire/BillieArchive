{% extends "base.html.twig" %}

{% trans_default_domain 'clan' %}

{% set setting = "vampire" %}

{% set element = clan %}

{% block title %}{{ "label.single"|trans }}{% endblock %}

{% block shortcuts %}
  {% if access_decision('edit', clan).isGranted %}
    <a class="btn btn-primary mb-2" href="{{ path('vampire_clan_edit', {id: clan.id}) }}">{% include "_icon.html.twig" with {icon : 'edit' } only %}</a>
  {% endif %}
  {% include "_back_entity.html.twig" with {name: 'vampire_clan'} %}
  {% include "_top.html.twig" %}
{% endblock %}

{% block body %}
  <div class="container block py-5">
    {% include "vampire/clan/_show.html.twig" with {clan : clan, isModal: 0} %}
  </div>
{% endblock %}