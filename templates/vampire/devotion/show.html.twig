{% extends "base.html.twig" %}

{% trans_default_domain 'vampire' %}

{% set setting = "vampire" %}

{% block title %}
  {{ devotion.name }}
{% endblock %}

{% block shortcuts %}
  {% if access_decision('edit', devotion).isGranted %}
    <a class="btn btn-primary mb-2" href="{{ path('vampire_devotion_edit', {'id': devotion.id }) }}">
      {% include "_icon.html.twig" with {icon: 'edit'} only %}
    </a>
  {% endif %}
  {{ parent() }}
{% endblock %}

{% block body %}
  
  <div class="container block py-3">
    {% include "vampire/devotion/_show.html.twig" with {options: 1} %}
  </div>
{% endblock %}
