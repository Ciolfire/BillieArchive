{% extends "base.html.twig" %}

{% trans_default_domain 'character' %}

{% if virtue is defined %}
  {% set type = "virtue" %}
{% else %}
  {% set type = "vice" %}
  {% set virtue = vice %}
{% endif %}

{% block shortcuts %}
  {% if access_decision('edit', virtue).isGranted %}
    <a class="btn btn-primary mb-2" href="{{ path("#{type}_edit", {id: virtue.id}) }}">
      {% include "_icon.html.twig" with {icon: 'edit'} only %}
    </a>
  {% endif %}
  {{ parent() }}
{% endblock %}

{% block title %}{{ virtue.name }}{% endblock %}

{% block body %}
  <div class="container block py-5">
    {% include "virtue/_show.html.twig" with {isModal: 0} %}
  </div>

  
{% endblock %}
