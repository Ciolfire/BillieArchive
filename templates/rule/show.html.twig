{% extends 'base.html.twig' %}

{% trans_default_domain 'app' %}

{% block title %}{{ rule.title }}{% endblock %}

{% block shortcuts %}
  {% if access_decision('edit', rule).isGranted %}
    <div class="mb-2">
      <a class="d-block btn btn-primary" href="{{ path('rule_edit', {'id': rule.id }) }}">{% include "_icon.html.twig" with {icon : 'edit' } only %}</a>
      {% if rule.parentRule is null %}
        <a class="d-block btn btn-primary mt-1" href="{{ path('rule_new', {setting: rule.type|default("human"), parent: rule.id}) }}">{% include "_icon.html.twig" with {icon : 'add' } only %}</a>
      {% endif %}
    </div>
  {% endif %}
  {% if rule.parentRule is null %}
    {% include "_back.html.twig" with {link: path('rule_index')} %}
  {% else %}
    {% include "_back.html.twig" with {link: path('rule_show', {id: rule.parentRule.id})} %}
  {% endif %}
{% endblock %}

{% block body %}
  <div class="container mt-5">
    {% include "rule/_show.html.twig" %}
  </div>
{% endblock %}
