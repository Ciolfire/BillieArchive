{% extends 'base.html.twig' %}

{% trans_default_domain 'app' %}

{% block title %}{{ rule.title }}{% endblock %}

{% block shortcuts %}
  {% if is_granted('ROLE_ST') and rule.parentRule is null %}
    <a class="btn btn-primary mt-1" href="{{ path('rule_new', {setting: rule.type|default("human"), parent: rule.id}) }}">{% include "_icon.html.twig" with {icon : 'add' } only %}</a>
  {% endif %}
  {% include "_back.html.twig" with {link: path('rule_index')} %}
{% endblock %}

{% block body %}
  <div class="container mt-5">
    {% include "rule/_show.html.twig" %}
  </div>
{% endblock %}
