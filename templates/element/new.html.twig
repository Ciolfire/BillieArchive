{% extends 'form.html.twig' %}

{% if element.setting is defined %}
  {% set setting = element.setting %}
{% endif %}


{% trans_default_domain 'app' %}

{% if entity.id is null %}
  {% set action = "new" %}
{% else %}
  {% set action = "edit" %}
{% endif %}

{% block title %}
  {{ ("label.single")|trans([], element) }}
  —
  {{ ("action." ~ action)|trans }}
{% endblock %}
