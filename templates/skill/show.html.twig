{% extends "base.html.twig" %}

{% trans_default_domain 'skill' %}

{% block title %}{{ skill.name }}{% endblock %}

{% block shortcuts %}
  {% if access_decision('edit', skill).isGranted %}
    <a class="btn btn-primary mb-2" href="{{ path('skill_edit', {id: skill.id}) }}">
      {% include "_icon.html.twig" with {icon: 'edit'} only %}
    </a>
  {% endif %}
  {{ parent() }}
{% endblock %}

{% block body %}
  <div class="container block py-5">
    {% include "skill/_show.html.twig" with {isModal: 0} %}
  </div>

  
{% endblock %}
