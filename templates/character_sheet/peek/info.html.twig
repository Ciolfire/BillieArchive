{% extends 'base.html.twig' %}

{% trans_default_domain 'character' %}

{% block title %}{{ "infos.details.perso"|trans }}{% endblock %}

{% block shortcuts %}
  {% if peeker.player == app.user %}
    {% include "_back.html.twig" with {link: path('character_show', {id: peeker.id, _fragment: "relation"})} %}
  {% elseif character.player == app.user %}
    {% include "_back.html.twig" with {link: path('character_show', {id: character.id, _fragment: "relation"})} %}
  {% else %}
    {# Should never happen #}
    
  {% endif %}
{% endblock %}

{% block body %}
  <h1>{{ character.publicName(peeker) }}</h1>
  <h2>{{ "infos.details.perso"|trans }}</h2>
  <div class="container">
    <div class="block">
      <div class="row">
        {% include "_form.html.twig" %}
      </div>
    </div>
  </div>
{% endblock %}
